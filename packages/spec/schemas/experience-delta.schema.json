{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erc-awar.dev/schemas/experience-delta.schema.json",
  "title": "ERC-83xx Experience Delta",
  "description": "Off-chain Experience Delta record (SPEC §4.1). Commitments only; raw memory lives off-chain.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "spaceId",
    "priorMemoryCommitment",
    "newContentCommitment",
    "memoryType",
    "schemaHash",
    "inferenceAnchor",
    "inputHash",
    "previousDelta",
    "timestamp",
    "version",
    "agent",
    "uri"
  ],
  "properties": {
    "schema": { "const": "erc83xx/delta/v0" },
    "spaceId": { "$ref": "#/$defs/bytes32" },
    "priorMemoryCommitment": { "$ref": "#/$defs/bytes32" },
    "newContentCommitment": { "$ref": "#/$defs/bytes32" },
    "memoryType": {
      "enum": [
        "TEXT",
        "EMBEDDING",
        "LATENT",
        "TOOL_TRACE",
        "EPISODIC",
        "POLICY",
        "SHARED_WORKING",
        "PROOF"
      ]
    },
    "schemaHash": { "$ref": "#/$defs/bytes32" },
    "inferenceAnchor": { "$ref": "#/$defs/bytes32" },
    "inputHash": { "$ref": "#/$defs/bytes32" },
    "previousDelta": { "$ref": "#/$defs/bytes32" },
    "timestamp": { "type": "integer", "minimum": 0 },
    "version": { "type": "integer", "minimum": 0 },
    "agent": { "$ref": "#/$defs/address" },
    "uri": {
      "type": "string",
      "pattern": "^(ipfs|ethstorage|ar|https)://"
    },
    "signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" }
  },
  "$defs": {
    "bytes32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    }
  }
}
